{
  "name": "paperlint",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.14.0",
    "pnpm": "10.33.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10",
      "uuid": "^14.0.0"
    }
  },
  "scripts": {
    "audit:repo": "pnpm clean && pnpm check && pnpm test:visual && pnpm clean",
    "build": "pnpm -r --if-present build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm db:reset && pnpm db:test && pnpm db:types:verify",
    "clean": "node ./scripts/clean-workspace.mjs",
    "dev": "pnpm --filter @reviselab/web dev",
    "dev:extension": "pnpm --filter @reviselab/extension dev",
    "dev:hosted": "node ./scripts/dev-hosted.mjs",
    "dev:hosted:check": "node ./scripts/check-supabase-stack.mjs --hosted",
    "dev:live": "node ./scripts/dev-live.mjs",
    "dev:local:sync-env": "node ./scripts/sync-local-env.mjs",
    "dev:services": "node ./scripts/dev-services.mjs",
    "dev:stack:check": "node ./scripts/check-local-stack.mjs",
    "dev:web": "pnpm --filter @reviselab/web dev",
    "dev:worker": "pnpm --filter @reviselab/worker dev",
    "db:reset": "node ./scripts/run-supabase-command.mjs db reset",
    "db:test": "node ./scripts/run-supabase-command.mjs test db",
    "db:types:verify": "node ./scripts/check-db-types.mjs",
    "fixtures:check": "node ./scripts/check-local-manuscripts.mjs",
    "fixtures:prepare": "node ./scripts/check-local-manuscripts.mjs --prepare",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "grobid:check": "node ./scripts/check-grobid.mjs",
    "lint": "pnpm clean && pnpm -r --if-present lint && node ./scripts/check-guardrails.mjs",
    "prod:check": "node ./scripts/check-production-readiness.mjs",
    "qa:real-manuscripts": "node ./scripts/evaluate-real-manuscripts.mjs",
    "railway:build": "node ./scripts/railway-command.mjs build",
    "railway:start": "node ./scripts/railway-command.mjs start",
    "rules:precision": "node ./scripts/rules-precision.mjs",
    "rules:precision:llm": "node ./scripts/rules-precision-llm.mjs",
    "smoke:hosted": "node ./scripts/smoke-hosted-review.mjs",
    "smoke:hosted:auth": "node ./scripts/smoke-auth-redirect.mjs",
    "smoke:hosted:pdf": "node ./scripts/smoke-hosted-review.mjs --pdf",
    "smoke:hosted:pdf:expect-failure": "node ./scripts/smoke-hosted-review.mjs --pdf --expect-failure",
    "smoke:live": "node ./scripts/smoke-live-review.mjs",
    "smoke:live:pdf": "node ./scripts/smoke-live-review.mjs --pdf",
    "start": "pnpm start:web",
    "start:web": "pnpm --filter @reviselab/web start",
    "start:worker": "pnpm --filter @reviselab/worker start",
    "test": "pnpm -r --if-present test",
    "test:hosted": "node ./scripts/check-supabase-stack.mjs --hosted && pnpm db:types:verify",
    "test:live": "node ./scripts/test-live-stack.mjs",
    "test:live:browser": "pnpm --filter @reviselab/web test:live",
    "test:visual": "pnpm --filter @reviselab/web test:visual",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "postgres": "^3.4.9",
    "prettier": "^3.6.2",
    "typescript": "^6.0.3"
  }
}

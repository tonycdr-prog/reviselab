# For local live mode, run `pnpm dev:services`, copy DATABASE_URL from
# `supabase status -o env`, and keep GROBID_URL pointed at the local container.
# For hosted Supabase dev, prefer the Session pooler or Transaction pooler URL.
# Direct db.<project>.supabase.co:5432 URLs can be IPv6-only.
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GROBID_URL=http://127.0.0.1:8070
